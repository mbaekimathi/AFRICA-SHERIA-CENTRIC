# =============================================================================
# Sheria-Centric — secrets only. Domain, DEBUG, hosts, CSRF all auto-pick.
# =============================================================================

# Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — only set what differs from local defaults
# Defaults: name=v.2-sheria-centric-db  user=root  host=127.0.0.1  port=3306
DB_PASSWORD=

# Production (cPanel) — domain is taken from the browser URL automatically.
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
