# =============================================================================
# Sheria-Centric — secrets only. Domain auto-picks from the browser URL.
# =============================================================================

# Google (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Google Cloud Console → APIs & Services → Credentials → OAuth Web client ---
# Authorized JavaScript origins (no trailing slash):
#   http://localhost:8000
#   https://baunilawgroup.com
#   https://www.baunilawgroup.com
#
# Authorized redirect URIs (trailing slash required):
#   http://localhost:8000/integrations/google/callback/
#   https://baunilawgroup.com/integrations/google/callback/
#   https://www.baunilawgroup.com/integrations/google/callback/
#
# In-app settings (NOT for Google Console):
#   http://localhost:8000/it-support/dashboard/google-drive-settings/
#   https://baunilawgroup.com/it-support/dashboard/google-drive-settings/


# --- M-Pesa (optional — prefer Finance Settings in the app) ---
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://yourdomain.com/integrations/mpesa/callback/
# MPESA_ENV=sandbox


# --- Email SMTP (optional — prefer Communication Settings in the app) ---
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourfirm.com
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false


# --- Local MySQL (XAMPP / MariaDB) — root with empty password is fine ---
DB_PASSWORD=
# Keep DB connections alive between requests (seconds). Helps under many sessions.
# DB_CONN_MAX_AGE=30
# If you see "Too many connections" under load, raise MySQL max_connections
# (e.g. SET GLOBAL max_connections = 200;) and keep passenger workers modest.

# --- cPanel (required) — use MySQL Databases values, NOT root ---
# DB_NAME=baunilaw_yourdb
# DB_USER=baunilaw_youruser
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
