SECRET_KEY=change-me-in-production
DEBUG=True
# Hostnames the app accepts. In DEBUG, LAN IPs are also allowed automatically.
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Production (cPanel): set DEBUG=False and list your domain(s), plus CSRF origins:
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# MySQL (required) — missing DB/tables are created on server start
DB_NAME=v.2-sheria-centric-db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# =============================================================================
# Google OAuth (Web client in Google Cloud Console)
#
# Client portal Google sign-in (/client/login/) needs Authorized JavaScript origins:
#   http://localhost:8000
#   http://127.0.0.1:8000
# (Private LAN IPs like 192.168.x.x are usually rejected by Google — use localhost.)
#
# Firm Drive connect needs Authorized redirect URIs:
#   http://localhost:8000/integrations/google/callback/
#   http://127.0.0.1:8000/integrations/google/callback/
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: company root folder name on Google Drive (default Sheria-Centric)
FIRM_DRIVE_ROOT_NAME=Sheria-Centric
# Display name in the workspace top bar
FIRM_DISPLAY_NAME=Sheria Law Firm
